# SSH Client Configuration Template
# Copy this to ~/.ssh/config and customize as needed

# Include machine-specific configurations (not tracked in git)
Include ~/.ssh/config.local

# 1Password SSH agent — auto-detect socket per OS (macOS / Linux).
# Which keys are exposed is controlled by ~/.config/1Password/ssh/agent.toml.
Match host * exec "test -S \"$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock\""
    IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"

Match host * exec "test -S \"$HOME/.1password/agent.sock\""
    IdentityAgent ~/.1password/agent.sock

# Global defaults
Host *
    # Security
    PasswordAuthentication no
    KbdInteractiveAuthentication no
    PubkeyAuthentication yes
    StrictHostKeyChecking ask

    # Performance
    Compression yes
    ServerAliveInterval 60
    ServerAliveCountMax 3
    TCPKeepAlive yes

    # Multiplexing for faster connections
    ControlMaster auto
    ControlPath ~/.ssh/sockets/%r@%h-%p
    ControlPersist 600

    # Use ssh-agent for key management
    AddKeysToAgent yes

    # 1Password's agent (filtered via agent.toml) decides which key to offer
    IdentitiesOnly no

# Example
# Host myserver
#     HostName server.example.com
#     User myusername
#     Port 22
#     IdentityFile ~/.ssh/id_rsa
#     ForwardAgent yes
