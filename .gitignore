# Packages #
############
# it's better to unpack these files and commit the raw source
# git has its own built in compression methods
*.7z
*.dmg
*.gz
*.iso
*.jar
*.rar
*.tar
*.zip

.history/
node_modules/
package.json
tsconfig.json

# Personal files #
##################
.zshrc.local
*.local
.env
.env.local
.claude/vps.env

# SSH configs with personal info #
##################################
# These files are stored in dotfiles/ but symlinked to ~/.ssh/
# This keeps all configs centralized while maintaining privacy
.ssh/config.local
.ssh/config.*.local
.ssh/config.work

# Sensitive data #
##################
**/id_*
**/*.pem
**/*.key
**/known_hosts
**/authorized_keys

# OS generated files #
######################
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

