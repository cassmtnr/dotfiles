# Ghostty configuration
# Docs: https://ghostty.org/docs/config/reference
# List themes: ghostty +list-themes | List fonts: ghostty +list-fonts
# Reload: Cmd+Shift+,

# --- Font ---
font-family = "Fira Code"
font-size = 14
# macOS font rendering enhancement
font-thicken = true

# --- Theme ---
# For light/dark auto-switching: theme = light:Nord Light,dark:Nord
theme = Nord

# --- Window ---
# in points
window-padding-x = 4
window-padding-y = 2
# rebalance padding on resize
window-padding-balance = true
window-save-state = always
window-inherit-working-directory = true
window-new-tab-position = end

# --- Cursor ---
cursor-style = block
cursor-style-blink = true

# --- Shell Integration ---
shell-integration = detect
shell-integration-features = cursor,sudo,title

# --- Clipboard ---
clipboard-read = allow
clipboard-write = allow
clipboard-trim-trailing-spaces = true
clipboard-paste-protection = false

# --- Scrollback ---
# ~10MB, allocated lazily
scrollback-limit = 10000000

# --- Key Bindings: Tab Navigation ---
keybind = cmd+one=goto_tab:1
keybind = cmd+two=goto_tab:2
keybind = cmd+three=goto_tab:3
keybind = cmd+four=goto_tab:4
keybind = cmd+five=goto_tab:5
keybind = cmd+six=goto_tab:6
keybind = cmd+seven=goto_tab:7
keybind = cmd+eight=goto_tab:8
keybind = cmd+nine=goto_tab:9

# --- Key Bindings: Text Navigation ---
# word backward
keybind = alt+left=text:\x1b\x62
# word forward
keybind = alt+right=text:\x1b\x66
# line start
keybind = cmd+left=text:\x01
# line end
keybind = cmd+right=text:\x05
keybind = cmd+k=clear_screen

# --- macOS ---
macos-icon = custom
macos-custom-icon = ~/dotfiles/.ghostty/icon.icns
macos-titlebar-style = native
# send escape sequences instead of special characters
macos-option-as-alt = true

# xterm-256color for SSH compatibility (xterm-ghostty terminfo often missing on remote hosts)
term = xterm-256color

# --- Misc ---
# prompt before closing with running processes
confirm-close-surface = true
mouse-hide-while-typing = true
# clickable URLs
link-url = true
keybind = shift+enter=text:\x1b\r
